# ── Base de datos ──────────────────────────────────────────────────────────────
# Local:
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=admin
DB_NAME=db_gestionEmpleadosTienda

# Railway asigna automáticamente MYSQLHOST, MYSQLPORT, MYSQLUSER,
# MYSQLPASSWORD y MYSQLDATABASE — no es necesario declararlos aquí.

# ── Autenticación JWT ──────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_segura

# true  → exige JWT en cada petición protegida
# false → modo desarrollo: asigna usuario ADMIN virtual sin verificar token
AUTH_ENABLED=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# URL del frontend en producción (Vercel).
# Dejar en blanco o no definir para permitir cualquier origen (*).
CLIENT_URL=https://tu-app.vercel.app
